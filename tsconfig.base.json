{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["DOM", "ESNext"],
    "target": "es2020",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@wanderapp/isomorphic-messaging": ["./libs/isomorphic-messaging/src/index.ts"],
      "@wanderapp/core": ["./libs/core/src/index.ts"],
      "@wanderapp/ui": ["./libs/ui/src/index.ts"]
    }
  },
  "exclude": [".old", ".old-already-moved"]
}
