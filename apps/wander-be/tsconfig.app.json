{
  "extends": "../../tsconfig.base.json",

  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["dom"],
    "types": ["node", "@nx/react/typings/cssmodule.d.ts", "@nx/react/typings/image.d.ts", "vite/client"],
    "rootDir": "src",

    // Added:

    "paths": {
      "@wanderapp/isomorphic-messaging": ["./libs/isomorphic-messaging/src/index.ts"],
      "@wanderapp/core": ["./libs/core/src/index.ts"],
      "@wanderapp/ui": ["./libs/ui/src/index.ts"],
      "~*": ["./src/*"],
      "~isomorphic-messaging": ["../../libs/isomorphic-messaging/src/lib/messaging/strategies/extension/extension-messaging.strategy.ts"],
      "~isomorphic-chunking": ["../../libs/isomorphic-messaging/src/lib/messaging/strategies/extension/extension-chunking.strategy.ts"]
    }
  },

  // Modified:

  "exclude": [
    "node_modules", // Added
    "out-tsc",
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/**/*.spec.js",
    "src/**/*.test.js",
    "src/**/*.spec.jsx",
    "src/**/*.test.jsx",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],

  "include": [
    ".plasmo/index.d.ts",
    // ".plasmo/**/*",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "./shim.d.ts"
, "../../libs/core/src/lib/utils/coingecko/coingecko.ts", "../../libs/core/src/lib/utils/mutex/mutex.ts", "../../libs/core/src/lib/utils/assertions/assertions.ts", "../../libs/core/src/lib/utils/browser-extension/icon.ts", "../../libs/core/src/lib/utils/browser-extension/context-menus.ts", "../../libs/core/src/lib/utils/browser-extension/runtime.ts"  ],
  "references": [
    {
      "path": "../../libs/ui/tsconfig.lib.json"
    }
  ]

  // Added:

  // Removed:
  // "extends": "plasmo/templates/tsconfig.base",
}
