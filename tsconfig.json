{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": ["node_modules", "wander-connect-sdk"],
  "include": [
    ".plasmo/index.d.ts",
    ".plasmo/**/*",
    "./**/*.ts",
    "./**/*.tsx",
    "./shim.d.ts",
    "vite.config.js",
    "vite.config.js"
  ],
  "compilerOptions": {
    "paths": {
      "~*": ["./src/*"],
      "~isomorphic-messaging": ["./src/utils/messaging/strategies/extension/extension-messaging.strategy.ts"],
      "~isomorphic-chunking": ["./src/utils/messaging/strategies/extension/extension-chunking.strategy.ts"]
    },
    "resolveJsonModule": true,
    "baseUrl": ".",
    "jsx": "react-jsx"
  }
}
